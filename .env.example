# --- Stellar network -------------------------------------------------------
# 'testnet' or 'mainnet'
NETWORK=testnet

# Soroban RPC endpoint.
#   testnet: https://soroban-testnet.stellar.org
#   mainnet: https://soroban-rpc.mainnet.stellar.gateway.fm (or your provider)
RPC_URL=https://soroban-testnet.stellar.org

# MUST match the canonical passphrase for NETWORK or the server refuses to boot:
#   testnet: Test SDF Network ; September 2015
#   mainnet: Public Global Stellar Network ; September 2015
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Deployed vault contract id (C...).
VAULT_CONTRACT_ID=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# --- API server ------------------------------------------------------------
PORT=3000

# Secret used to sign/verify JWTs. Use a long, random value in production.
JWT_SECRET=change-me-to-a-long-random-secret

# --- Database --------------------------------------------------------------
# SQLite file path (better-sqlite3).
DB_FILE=./stellaraid.db
